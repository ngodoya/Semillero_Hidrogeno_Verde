{
    "latex-workshop.latex.outDir": "%DIR%/.build",

    "latex-workshop.latex.tools": [
        {
            "name": "latexmk_builddir",
            "command": "latexmk",
            "args": [
                "-pdf",
                "-interaction=nonstopmode",
                "-synctex=1",
                "-outdir=%DIR%/.build",
                "%DOC%"
            ]
        }
    ],

    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk (build dir)",
            "tools": ["latexmk_builddir"]
        }
    ]
}
